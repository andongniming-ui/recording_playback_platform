# Copy this file to .env and customize for your environment.
# All variables use the AR_ prefix (pydantic-settings env_prefix).

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local dev, zero-config):
# AR_DB_TYPE=sqlite
# AR_DB_URL=sqlite+aiosqlite:///./data/arex_recorder.db

# MySQL (this project uses MySQL via docker-compose, port 3307):
AR_DB_TYPE=mysql
AR_DB_URL=mysql+aiomysql://arex:arex123@127.0.0.1:3307/arex_recorder

# ── Security ──────────────────────────────────────────────────────────────────
# IMPORTANT: change this to a random 32+ character string in production.
AR_SECRET_KEY=changeme-in-production
# Set true in production to refuse startup when AR_SECRET_KEY keeps the default value.
AR_ENFORCE_SECURE_SECRET=false

# ── AREX Storage ──────────────────────────────────────────────────────────────
# URL of the AREX storage service (arex-storage-service).
AR_AREX_STORAGE_URL=http://127.0.0.1:8000

# Optional separate URL for the AREX agent storage endpoint.
# Leave empty to fall back to AR_AREX_STORAGE_URL.
AR_AREX_AGENT_STORAGE_URL=

# Path to the AREX Java agent JAR used when launching apps via SSH.
AR_AREX_AGENT_JAR_PATH=/home/test/arex-agent/arex-agent.jar

# ── SSH ───────────────────────────────────────────────────────────────────────
# Directory where SSH private keys are stored (one file per application).
AR_SSH_KEYS_DIR=./ssh_keys

# ── CORS ──────────────────────────────────────────────────────────────────────
# Allowed origins for CORS. List explicit origins — do NOT use ["*"] with credentials.
# Add your frontend URL here (e.g. http://your-server-ip:5173).
AR_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── First-run admin ────────────────────────────────────────────────────────────
# Password for the initial admin account (created only when the user table is empty).
# Leave empty to auto-generate a random password (printed to stderr on first start).
AR_ADMIN_INIT_PASSWORD=

# ── Debug ─────────────────────────────────────────────────────────────────────
AR_DEBUG=false

# ── JWT Tokens ────────────────────────────────────────────────────────────────
AR_ACCESS_TOKEN_EXPIRE_MINUTES=60
AR_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Replay Defaults ───────────────────────────────────────────────────────────
AR_DEFAULT_REPLAY_CONCURRENCY=5
AR_DEFAULT_REPLAY_TIMEOUT_MS=5000

# Seconds to wait after replay for AREX agent to flush sub-call reports.
AR_AREX_FLUSH_DELAY_S=1.0
# Retry count and interval when sub-call query is still empty after flush.
AR_AREX_FLUSH_MAX_RETRIES=3
AR_AREX_FLUSH_RETRY_INTERVAL_S=0.5

# ── Logging ───────────────────────────────────────────────────────────────────
# Leave empty to disable file logging.
AR_LOG_FILE=
AR_LOG_MAX_BYTES=10485760
AR_LOG_BACKUP_COUNT=5

# ── Optional N-LS MySQL (for bank_sub_call_log enrichment) ───────────────────
AR_NLS_MYSQL_HOST=
AR_NLS_MYSQL_PORT=3306
AR_NLS_MYSQL_USER=root
AR_NLS_MYSQL_PASSWORD=

# ── Optional Didi MySQL (for JdbcTemplate sub-call enrichment) ───────────────
AR_DIDI_MYSQL_HOST=
AR_DIDI_MYSQL_PORT=3306
AR_DIDI_MYSQL_USER=root
AR_DIDI_MYSQL_PASSWORD=
AR_DIDI_MYSQL_DB_SAT=
AR_DIDI_MYSQL_DB_UAT=
