# AI Gateway (new-api) intranet deployment configuration.
# Copy to .env.ai-gateway and fill in values before running deploy-ai-gateway.sh.

NEW_API_IMAGE=calciumion/new-api:latest
MYSQL_IMAGE=mysql:8.0
REDIS_IMAGE=redis:7-alpine

NEW_API_PORT=13000

# IMPORTANT: change this password before deploying
MYSQL_ROOT_PASSWORD=CHANGE_ME_NEWAPI_DB_PASSWORD
