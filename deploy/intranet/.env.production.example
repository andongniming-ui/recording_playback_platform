# Copy to .env.production and replace all CHANGE_ME values before deploying inside the intranet.
# Keep this file as a template only. Do not commit the real .env.production with passwords.

COMPOSE_PROJECT_NAME=arex-recorder

# ---- Internal image registry / Docker source ----
# Import or mirror these images before deploying. Intranet deploy never builds images.
INTRANET_REGISTRY=registry.intranet.example.com/arex-recorder
PYTHON_BASE_IMAGE=registry.intranet.example.com/library/python:3.11-slim
NODE_BASE_IMAGE=registry.intranet.example.com/library/node:18-bullseye-slim
MYSQL_IMAGE=registry.intranet.example.com/library/mysql:8.0
BACKEND_IMAGE=registry.intranet.example.com/arex-recorder/backend:1.0.0
FRONTEND_IMAGE=registry.intranet.example.com/arex-recorder/frontend:1.0.0
BUILD_IMAGES=false

# ---- Internal pip/npm source ----
PIP_INDEX_URL=http://pypi.intranet.example.com/simple
PIP_EXTRA_INDEX_URL=
PIP_TRUSTED_HOST=pypi.intranet.example.com
NPM_REGISTRY=http://npm.intranet.example.com/repository/npm/

# ---- Platform ports ----
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=5173
MYSQL_HOST_PORT=3307

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=arex_recorder
MYSQL_USER=arex
MYSQL_PASSWORD=CHANGE_ME_AREX_PASSWORD
AR_DB_URL=mysql+aiomysql://arex:CHANGE_ME_AREX_PASSWORD@db:3306/arex_recorder

# ---- Backend security ----
AR_SECRET_KEY=CHANGE_ME_RANDOM_32_PLUS_CHARS
AR_ENFORCE_SECURE_SECRET=true
AR_ADMIN_INIT_PASSWORD=CHANGE_ME_INITIAL_ADMIN_PASSWORD
AR_DEBUG=false

# ---- Public URLs reachable by browsers and tested systems ----
# PLATFORM_HOST should be the intranet IP or DNS name of the platform server.
PLATFORM_HOST=192.168.x.x
FRONTEND_PUBLIC_ORIGIN=http://192.168.x.x:5173
BACKEND_PUBLIC_ORIGIN=http://192.168.x.x:8000
VITE_API_BASE_URL=http://192.168.x.x:8000/api/v1
AR_CORS_ORIGINS=["http://192.168.x.x:5173"]

# ---- AREX storage / agent ----
# This platform backend exposes the storage-compatible endpoint used by the agent.
AR_AREX_STORAGE_URL=http://127.0.0.1:8000
AR_AREX_AGENT_STORAGE_URL=http://192.168.x.x:8000
AR_DOCKER_AGENT_STORAGE_URL=http://192.168.x.x:8000
AREX_AGENT_VERSION=0.4.8
AR_AREX_AGENT_JAR_PATH=/opt/arex/arex-agent.jar

# ---- Replay defaults ----
AR_DEFAULT_REPLAY_CONCURRENCY=5
AR_DEFAULT_REPLAY_TIMEOUT_MS=5000
AR_REPLAY_JOB_HEARTBEAT_INTERVAL_S=5
AR_REPLAY_JOB_HEARTBEAT_TIMEOUT_S=300

# ---- Optional system plugin configs. Leave empty unless the intranet environment uses them. ----
AR_NLS_MYSQL_HOST=
AR_NLS_MYSQL_PORT=3306
AR_NLS_MYSQL_USER=root
AR_NLS_MYSQL_PASSWORD=
AR_DIDI_MYSQL_HOST=
AR_DIDI_MYSQL_PORT=3306
AR_DIDI_MYSQL_USER=root
AR_DIDI_MYSQL_PASSWORD=
AR_DIDI_MYSQL_DB_SAT=
AR_DIDI_MYSQL_DB_UAT=
