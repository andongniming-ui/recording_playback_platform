  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const now = new Date();",
          "const pad = (n, w) => String(n).padStart(w, '0');",
          "const requestTime = now.getFullYear() + pad(now.getMonth() + 1, 2) + pad(now.getDate(), 2) + pad(now.getHours(), 2) + pad(now.getMinutes(), 2) + pad(now.getSeconds(), 2) + pad(now.getMilliseconds(), 3);",
          "const traId = requestTime + String(Math.floor(Math.random() * 10));",
          "const requestNo = 'REQ-' + requestTime + '-' + pad(Math.floor(Math.random() * 1000), 3);",
          "pm.collectionVariables.set('requestTime', requestTime);",
          "pm.collectionVariables.set('traId', traId);",
          "pm.collectionVariables.set('requestNo', requestNo);",
          "pm.variables.set('requestTime', requestTime);",
          "pm.variables.set('traId', traId);",
          "pm.variables.set('requestNo', requestNo);"
        ]
      }
    }
  ]
}
