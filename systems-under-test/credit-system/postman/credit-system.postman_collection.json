  "item": [
    {
      "name": "CRD_ADMIT 准入",
      "description": "准入请求会按客户、产品和金额走不同的外部征信、反欺诈、多头借贷和联系人稳定性子调用。",
      "item": [
        {
          "name": "CRD_ADMIT C10001 P001 标准通过",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/xml"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<request>\n  <txn_code>CRD_ADMIT</txn_code>\n  <tra_id>{{traId}}</tra_id>\n  <request_time>{{requestTime}}</request_time>\n  <request_no>{{requestNo}}</request_no>\n  <customer_id>C10001</customer_id>\n  <product_id>P001</product_id>\n  <id_no>310101199001011234</id_no>\n  <mobile>13800000001</mobile>\n  <apply_amount>80000</apply_amount>\n  <apply_term>12</apply_term>\n  <apply_city>SHANGHAI</apply_city>\n</request>"
            },
            "url": {
              "raw": "{{baseUrl}}/credit/gateway",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "credit",
                "gateway"
              ]
            },
            "description": "标准通过链路。通常会查客户、产品、黑名单、历史，并调用 credit-score、fraud、internal risk。"
          }
        },
