{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-dating0000001",
    "name": "dating-system",
    "description": "AREX Recorder demo target system - 交友平台. Import into Postman and select a dating-system environment. Each request auto-generates an 18-digit trace_id and sends it in the XML body so logs can be searched end-to-end.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:28090"
    },
    {
      "key": "traceId",
      "value": ""
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-generate 18-digit traceId for each request",
          "let traceId = pm.variables.get('traceId');",
          "if (!traceId) {",
          "    let d = Math.floor(Math.random() * 9) + 1;",
          "    let rest = '';",
          "    for (let i = 1; i < 18; i++) {",
          "        rest += Math.floor(Math.random() * 10);",
          "    }",
          "    traceId = d + rest;",
          "}",
          "pm.variables.set('traceId', traceId);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "DAT001 用户注册",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/xml"}],
        "body": {
          "mode": "raw",
          "raw": "<request>\n  <tran_code>DAT001</tran_code>\n  <trace_id>{{traceId}}</trace_id>\n  <user_id>U20001</user_id>\n  <phone>13900002001</phone>\n  <gender>M</gender>\n  <age>28</age>\n  <city>BEIJING</city>\n</request>"
        },
        "url": {"raw": "{{baseUrl}}/api/dating/service", "host": ["{{baseUrl}}"], "path": ["api","dating","service"]},
        "description": "交易码：DAT001\n子调用：GET /internal/dating/risk-verify（风控校验）\n数据库：INSERT t_user\ntrace_id：每次发送前自动生成 18 位数字"
      }
    },
    {
      "name": "DAT002 用户登录",
