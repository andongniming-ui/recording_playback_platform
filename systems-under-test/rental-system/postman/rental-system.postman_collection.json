  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "let traId = String(Math.floor(Math.random() * 9) + 1);",
          "while (traId.length < 18) {",
          "  traId += String(Math.floor(Math.random() * 10));",
          "}",
          "pm.collectionVariables.set(\"traId\", traId);",
          "pm.variables.set(\"traId\", traId);"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const text = pm.response.text();",
          "const orderMatch = text.match(/<order_no>([^<]+)<\\/order_no>/) || text.match(/\"orderNo\"\\s*:\\s*\"([^\"]+)\"/);",
          "if (orderMatch) {",
          "  pm.collectionVariables.set(\"orderNo\", orderMatch[1]);",
          "  pm.variables.set(\"orderNo\", orderMatch[1]);",
          "}",
          "const paymentMatch = text.match(/<payment_no>([^<]+)<\\/payment_no>/) || text.match(/\"paymentNo\"\\s*:\\s*\"([^\"]+)\"/);",
          "if (paymentMatch) {",
          "  pm.collectionVariables.set(\"paymentNo\", paymentMatch[1]);",
          "  pm.variables.set(\"paymentNo\", paymentMatch[1]);",
          "}"
        ]
      }
    }
  ]
