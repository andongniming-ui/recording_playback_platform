    {
      "name": "Gateway XML",
      "description": "XML gateway examples. The underlying business logic is the same as the JSON gateway, but txnCode and params are sent in XML.",
      "item": [
        {
          "name": "PLACE_ORDER XML",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/xml" }
            ],
            "body": {
              "mode": "raw",
              "raw": "<request>\n  <txnCode>PLACE_ORDER</txnCode>\n  <params>\n    <customerId>{{customerId}}</customerId>\n    <merchantId>{{merchantId}}</merchantId>\n    <orderId>{{orderId}}</orderId>\n    <productId>{{productId}}</productId>\n    <basePrice>{{basePrice}}</basePrice>\n    <originalAmount>{{originalAmount}}</originalAmount>\n    <amount>{{amount}}</amount>\n    <riderId>{{riderId}}</riderId>\n  </params>\n</request>"
            },
            "url": "{{baseUrl}}/waimai/gateway/execute",
            "description": "XML 主入口示例\n对应复杂交易 PLACE_ORDER\n会触发 pricing / discount / risk 三个内部子调用"
          }
        },
        {
          "name": "LIST_CATEGORIES XML",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/xml" }
            ],
            "body": {
              "mode": "raw",
              "raw": "<request>\n  <txnCode>LIST_CATEGORIES</txnCode>\n  <params />\n</request>"
            },
            "url": "{{baseUrl}}/waimai/gateway/execute",
            "description": "XML 简单交易示例\n无子调用，无数据库访问"
          }
        }
      ]
    },
    {
      "name": "Internal APIs",
      "description": "Direct calls to the internal HTTP services used by complex transactions. These endpoints are normally invoked from inside the service through RestTemplate.",
      "item": [
        {
          "name": "pricing",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"basePrice\": \"{{basePrice}}\",\n  \"originalAmount\": \"{{originalAmount}}\",\n  \"customerId\": \"{{customerId}}\",\n  \"merchantId\": \"{{merchantId}}\"\n}"
            },
            "url": "{{baseUrl}}/waimai/internal/pricing",
            "description": "内部定价接口\nA/B 差异：compare 会启用 +8% 定价调整，并可能加收额外费用"
          }
        },
        {
          "name": "discount",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"originalAmount\": \"{{originalAmount}}\",\n  \"customerId\": \"{{customerId}}\"\n}"
            },
            "url": "{{baseUrl}}/waimai/internal/discount",
            "description": "内部优惠接口\nA/B 差异：compare 将优惠倍率从 1.0 调整到 1.5，并可能带配送险"
          }
        },
        {
          "name": "risk",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"orderId\": \"{{orderId}}\",\n  \"amount\": \"{{amount}}\"\n}"
            },
            "url": "{{baseUrl}}/waimai/internal/risk",
            "description": "内部风控接口\nA/B 差异：compare 将阈值从 80 提高到 85\n注意：riskScore 使用随机数，天然容易产生比对差异"
          }
        },
        {
          "name": "delivery-time",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"riderId\": \"{{riderId}}\"\n}"
            },
            "url": "{{baseUrl}}/waimai/internal/delivery-time",
            "description": "内部配送预估接口\nA/B 差异：compare 开启配送险\n注意：estimatedMinutes 使用随机数，天然容易产生比对差异"
          }
        }
      ]
    }
  ]
}
